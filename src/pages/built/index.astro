---
import ArtifactCard from '../../components/ArtifactCard.astro';
import { getPublishedArtifacts } from '../../lib/content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const artifacts = await getPublishedArtifacts();
---

<BaseLayout title="Built" description="Public tools and repositories.">
  <section class="mx-auto max-w-6xl px-5 py-12 sm:px-8 lg:px-12">
    <h1 class="text-balance font-display text-5xl font-bold leading-[0.95] tracking-[-0.05em] text-text-primary sm:text-7xl">Built</h1>
    <p class="mt-6 max-w-2xl text-pretty leading-8 text-text-secondary">
      Public tools and repositories.
    </p>

    <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {artifacts.map((artifact) => <ArtifactCard artifact={artifact} headingLevel="h2" />)}
    </div>
  </section>
</BaseLayout>
