    "@smui/form-field": "^5.0.0-beta.7",
    "@smui/icon-button": "^5.0.0-beta.7",
    "@smui/list": "^5.0.0-beta.7",
    "@smui/ripple": "^5.0.0-beta.7",
    "@smui/top-app-bar": "^5.0.0-beta.7",
    "@sveltejs/adapter-static": "^1.0.0-next.20",
    "@sveltejs/kit": "next",
    "smui-theme": "^5.0.0-beta.7",
    "svelte": "^3.42.6",
    "svelte-check": "^2.2.6",
