---
import { site } from '../data/site';
---

<div class="panel grid gap-5 p-5 md:grid-cols-[1fr_auto] md:items-center md:p-6">
  <p class="max-w-xl text-pretty font-mono text-sm leading-7 text-text-secondary">
    If you need someone to make backend systems less fragile, email me.
  </p>
  <div class="space-y-2 border-border md:border-l md:pl-8">
    <a href={`mailto:${site.email}`} class="block font-mono text-sm text-primary hover:text-primary-soft">{site.email}</a>
    <a href={site.linkedin} class="block font-mono text-sm text-primary hover:text-primary-soft" rel="noreferrer">
      linkedin.com/in/tulioanjos
    </a>
  </div>
</div>
