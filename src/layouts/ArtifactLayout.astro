---
import type { CollectionEntry } from 'astro:content';
import { getEntries } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Prose from '../components/Prose.astro';
import WritingRow from '../components/WritingRow.astro';

type Props = { artifact: CollectionEntry<'artifacts'> };
const { artifact } = Astro.props;
const primaryExternal = artifact.data.primaryAction.href.startsWith('http');
const secondaryExternal = artifact.data.secondaryAction?.href.startsWith('http') ?? false;
const relatedWriting =
  artifact.data.relatedWriting.length > 0
    ? (await getEntries(artifact.data.relatedWriting))
        .filter((post) => !post.data.draft)
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    : [];
---

<BaseLayout title={artifact.data.title} description={artifact.data.description}>
  <article class="px-5 py-12 sm:px-8 lg:px-12">
    <a href="/artifacts/" class="font-mono text-sm text-primary hover:text-primary-soft">&larr; Artifacts</a>

    <header class="mt-8 max-w-3xl">
      <p class="field-label">{artifact.data.type.replaceAll('-', ' ')} · {artifact.data.status}</p>
      <h1 class="mt-3 text-balance font-mono text-4xl font-bold text-text-primary sm:text-5xl">
        {artifact.data.title}
      </h1>
      <p class="mt-5 text-pretty text-lg leading-8 text-text-secondary">{artifact.data.description}</p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href={artifact.data.primaryAction.href}
          class="rounded-md border border-primary px-4 py-2 font-mono text-sm text-primary transition hover:bg-primary hover:text-background"
          {...(primaryExternal ? { rel: 'noreferrer' } : {})}
        >
          {artifact.data.primaryAction.label}
        </a>
        {artifact.data.secondaryAction && (
          <a
            href={artifact.data.secondaryAction.href}
            class="rounded-md border border-border px-4 py-2 font-mono text-sm text-text-secondary transition hover:border-primary hover:text-primary"
            {...(secondaryExternal ? { rel: 'noreferrer' } : {})}
          >
            {artifact.data.secondaryAction.label}
          </a>
        )}
      </div>
    </header>

    <Prose>
      <slot />
    </Prose>

    {relatedWriting.length > 0 && (
      <section class="mt-10 border-t border-border pt-8">
        <h2 class="font-mono text-2xl text-primary">Related writing</h2>
        <div class="mt-5 overflow-hidden rounded-[var(--radius-panel)] border border-border bg-surface/80">
          {relatedWriting.map((post) => <WritingRow post={post} />)}
        </div>
      </section>
    )}
  </article>
</BaseLayout>
