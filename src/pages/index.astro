---
import ArtifactCard from '../components/ArtifactCard.astro';
import PersonJsonLd from '../components/PersonJsonLd.astro';
import Timeline from '../components/Timeline.astro';
import WritingRow from '../components/WritingRow.astro';
import { getPublishedArtifacts, getPublishedWriting } from '../lib/content';
import { formatDate } from '../lib/dates';
import BaseLayout from '../layouts/BaseLayout.astro';

const artifacts = (await getPublishedArtifacts()).filter((artifact) => artifact.data.featured).slice(0, 3);
const writing = (await getPublishedWriting()).slice(0, 3);
const latestPost = writing[0];
const olderWriting = writing.slice(1);
---

<BaseLayout>
  <PersonJsonLd slot="head" />

  <section class="mx-auto max-w-6xl px-5 pb-8 pt-10 sm:px-8 sm:pt-12 lg:px-12">
    <div class="max-w-4xl">
      <h1 class="font-display text-5xl font-bold leading-[0.88] tracking-[-0.065em] text-text-primary sm:text-6xl lg:text-7xl">
        <span class="block">Túlio Ribeiro</span>
        <span class="block">dos Anjos</span>
      </h1>
      <p class="mt-5 max-w-2xl text-pretty text-lg leading-8 text-text-secondary">
        Backend systems engineer working mostly in .NET, Java, AWS, and integrations: getting two systems to agree and stay agreed.
      </p>
      <p class="mt-5 font-mono text-sm leading-6 text-text-muted">
        Campo Grande, Brazil · GMT-4 · backend contracts from 2026 · <a href="mailto:mail@tulio.org" class="underline decoration-current/35 underline-offset-4 hover:text-text-primary">mail@tulio.org</a>
      </p>
    </div>
  </section>

  <section id="writing" class="mx-auto max-w-6xl px-5 py-7 sm:px-8 lg:px-12">
    <div class="mb-5 flex items-end justify-between gap-4">
      <h2 class="font-mono text-xs uppercase tracking-[0.12em] text-text-muted">01 / writing</h2>
      <a href="/writing/" class="font-mono text-xs tracking-[0.08em] text-text-muted hover:text-text-primary">all writing &rarr;</a>
    </div>

    {latestPost && (
      <article class="max-w-4xl border-t border-primary/70 py-6">
        <a href={`/writing/${latestPost.id}/`} class="block">
          <time class="font-mono text-xs tabular-nums text-text-muted" datetime={latestPost.data.date.toISOString()}>
            {formatDate(latestPost.data.date)}
          </time>
          <h3 class="mt-3 max-w-3xl font-display text-3xl font-semibold leading-[0.95] tracking-[-0.045em] text-text-primary hover:text-primary sm:text-4xl">
            {latestPost.data.title}
          </h3>
          <p class="mt-4 max-w-2xl text-base leading-7 text-text-secondary">{latestPost.data.description}</p>
        </a>
      </article>
    )}

    <div class="max-w-4xl">
      {olderWriting.map((post) => <WritingRow post={post} />)}
    </div>
  </section>

  <section id="built" class="mx-auto max-w-6xl px-5 py-7 sm:px-8 lg:px-12">
    <div class="mb-5 flex items-end justify-between gap-4">
      <h2 class="font-mono text-xs uppercase tracking-[0.12em] text-text-muted">02 / built</h2>
      <a href="/built/" class="font-mono text-xs tracking-[0.08em] text-text-muted hover:text-text-primary">all built &rarr;</a>
    </div>
    <div class="max-w-4xl">
      {artifacts.map((artifact) => <ArtifactCard artifact={artifact} />)}
    </div>
  </section>

  <Timeline limit={2} showAllLink />
</BaseLayout>
