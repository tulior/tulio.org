---
import type { TimelineItem as TimelineItemType } from '../data/timeline';

type Props = { item: TimelineItemType };
const { item } = Astro.props;
const current = item.tone === 'current';
---

<li class="relative grid gap-3 pb-3 pl-10 md:grid-cols-[9rem_1fr] md:gap-5">
  <span class:list={[current ? 'timeline-dot-current' : 'timeline-dot', 'absolute left-[0.28rem] top-5 z-10']} aria-hidden="true" />

  <div class:list={['font-mono text-sm tabular-nums', current ? 'text-primary' : 'text-text-muted']}>
    {item.period}
  </div>

  <article class:list={['border-t border-border py-4', current && 'border-primary']}>
    <h3 class="text-base font-semibold text-text-primary">{item.title}</h3>
    {item.place && <p class="mt-1 font-mono text-xs text-text-muted">{item.place}</p>}
    <p class="mt-3 text-pretty text-sm leading-6 text-text-secondary">{item.summary}</p>
    {item.stack && item.stack.length > 0 && (
      <p class="mt-3 font-mono text-xs leading-6 text-text-muted">
        {item.stack.join(' · ')}
      </p>
    )}
  </article>
</li>
