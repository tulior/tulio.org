---
import type { CollectionEntry } from 'astro:content';

type Props = { artifact: CollectionEntry<'artifacts'>; headingLevel?: 'h2' | 'h3' };
const { artifact, headingLevel = 'h3' } = Astro.props;
const Heading = headingLevel;

const typeLabel = artifact.data.type.replaceAll('-', ' ');
const primaryExternal = artifact.data.primaryAction.href.startsWith('http');
const secondaryExternal = artifact.data.secondaryAction?.href.startsWith('http') ?? false;
---

<article class="border-t border-border py-6">
  <p class="font-mono text-[0.7rem] uppercase tracking-[0.1em] text-text-muted">
    {typeLabel} · {artifact.data.status}
  </p>

  <Heading class="mt-3 text-2xl font-semibold tracking-tight text-text-primary">
    <a href={`/built/${artifact.id}/`} class="hover:text-primary">{artifact.data.title}</a>
  </Heading>

  <p class="mt-3 max-w-2xl text-pretty text-base leading-7 text-text-secondary">{artifact.data.description}</p>

  {artifact.data.stack.length > 0 && (
    <p class="mt-3 max-w-2xl font-mono text-xs leading-6 text-text-muted">
      {artifact.data.stack.join(' · ')}
    </p>
  )}

  <div class="mt-4 flex flex-wrap gap-x-5 gap-y-2 font-mono text-xs tracking-[0.08em] text-text-muted">
    <a href={artifact.data.primaryAction.href} class="hover:text-text-primary" {...(primaryExternal ? { rel: 'noreferrer' } : {})}>
      {artifact.data.primaryAction.label} &rarr;
    </a>
    {artifact.data.secondaryAction && (
      <a href={artifact.data.secondaryAction.href} class="hover:text-text-primary" {...(secondaryExternal ? { rel: 'noreferrer' } : {})}>
        {artifact.data.secondaryAction.label} &rarr;
      </a>
    )}
  </div>
</article>
