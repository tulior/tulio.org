---
import type { CollectionEntry } from 'astro:content';
import { getEntries } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Prose from '../components/Prose.astro';
import WritingRow from '../components/WritingRow.astro';

type Props = { artifact: CollectionEntry<'artifacts'> };
const { artifact } = Astro.props;
const primaryExternal = artifact.data.primaryAction?.href.startsWith('http') ?? false;
const secondaryExternal = artifact.data.secondaryAction?.href.startsWith('http') ?? false;
const relatedWriting =
  artifact.data.relatedWriting.length > 0
    ? (await getEntries(artifact.data.relatedWriting))
        .filter((post) => !post.data.draft)
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    : [];
const imagePath = `/built/${artifact.id}/og.png`;
---

<BaseLayout title={artifact.data.title} description={artifact.data.description} imagePath={imagePath}>
  <article class="mx-auto max-w-6xl px-5 py-12 sm:px-8 lg:px-12">
    <a href="/built/" class="font-mono text-sm text-text-muted hover:text-text-primary">&larr; Built</a>

    <header class="mt-8 max-w-4xl">
      <p class="field-label">{artifact.data.type.replaceAll('-', ' ')} · {artifact.data.status}</p>
      <h1 class="mt-3 text-balance font-display text-5xl font-bold leading-[0.95] tracking-[-0.05em] text-text-primary sm:text-7xl">
        {artifact.data.title}
      </h1>
      <p class="mt-6 max-w-[60ch] text-pretty text-lg leading-8 text-text-secondary">{artifact.data.description}</p>
      {(artifact.data.primaryAction || artifact.data.secondaryAction) && (
        <div class="mt-6 flex flex-wrap gap-x-5 gap-y-2 font-mono text-xs tracking-[0.08em] text-text-muted">
          {artifact.data.primaryAction && (
            <a href={artifact.data.primaryAction.href} class="hover:text-text-primary" {...(primaryExternal ? { rel: 'noreferrer' } : {})}>
              {artifact.data.primaryAction.label} &rarr;
            </a>
          )}
          {artifact.data.secondaryAction && (
            <a href={artifact.data.secondaryAction.href} class="hover:text-text-primary" {...(secondaryExternal ? { rel: 'noreferrer' } : {})}>
              {artifact.data.secondaryAction.label} &rarr;
            </a>
          )}
        </div>
      )}
    </header>

    <Prose>
      <slot />
    </Prose>

    {relatedWriting.length > 0 && (
      <section class="mt-12 max-w-4xl border-t border-border pt-8">
        <h2 class="font-display text-3xl font-semibold tracking-[-0.04em] text-text-primary">Related writing</h2>
        <div class="mt-5">
          {relatedWriting.map((post) => <WritingRow post={post} />)}
        </div>
      </section>
    )}
  </article>
</BaseLayout>
