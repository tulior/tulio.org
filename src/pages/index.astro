---
import { Image } from 'astro:assets';
import portrait from '../assets/tulio-ribeiro-dos-anjos.jpg';
import ArtifactCard from '../components/ArtifactCard.astro';
import PersonJsonLd from '../components/PersonJsonLd.astro';
import Timeline from '../components/Timeline.astro';
import WritingRow from '../components/WritingRow.astro';
import { getPublishedArtifacts, getPublishedWriting } from '../lib/content';
import BaseLayout from '../layouts/BaseLayout.astro';

const artifacts = (await getPublishedArtifacts()).filter((artifact) => artifact.data.featured).slice(0, 3);
const writing = (await getPublishedWriting()).slice(0, 3);
---

<BaseLayout>
  <PersonJsonLd slot="head" />

  <section class="mx-auto max-w-6xl px-5 pb-10 pt-12 sm:px-8 sm:pt-16 lg:px-12">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_16rem] lg:items-start">
      <div class="max-w-3xl">
        <h1 class="text-balance font-display text-5xl font-bold leading-[0.95] tracking-[-0.05em] text-text-primary sm:text-7xl">
          Túlio Ribeiro dos Anjos
        </h1>
        <p class="mt-5 max-w-xl text-pretty text-lg leading-8 text-text-secondary">
          Backend systems engineer working mostly in .NET, Java, AWS, and integrations: getting two systems to agree and stay agreed.
        </p>
        <p class="mt-5 font-mono text-sm leading-6 text-text-muted">
          Campo Grande, Brazil · GMT-4 · available for backend contract work from 2026 · <a href="mailto:mail@tulio.org" class="text-text-primary underline decoration-primary/40 underline-offset-4 hover:text-primary">mail@tulio.org</a>
        </p>
      </div>

      <figure class="w-40 sm:w-48 lg:ml-auto lg:w-64">
        <div class="overflow-hidden bg-surface-inset">
          <Image
            src={portrait}
            alt="Túlio Ribeiro dos Anjos"
            width={512}
            height={512}
            loading="eager"
            class="aspect-square w-full object-cover"
            decoding="async"
            fetchpriority="high"
          />
        </div>
      </figure>
    </div>
  </section>

  <section id="writing" class="mx-auto max-w-6xl px-5 py-8 sm:px-8 lg:px-12">
    <div class="mb-5 flex items-end justify-between gap-4">
      <h2 class="font-display text-3xl font-semibold tracking-[-0.04em] text-text-primary">Writing</h2>
      <a href="/writing/" class="font-mono text-xs tracking-[0.08em] text-text-muted hover:text-text-primary">all writing &rarr;</a>
    </div>
    <div class="max-w-4xl">
      {writing.map((post) => <WritingRow post={post} />)}
    </div>
  </section>

  <section id="built" class="mx-auto max-w-6xl px-5 py-8 sm:px-8 lg:px-12">
    <div class="mb-5 flex items-end justify-between gap-4">
      <h2 class="font-display text-3xl font-semibold tracking-[-0.04em] text-text-primary">Built</h2>
      <a href="/built/" class="font-mono text-xs tracking-[0.08em] text-text-muted hover:text-text-primary">all built &rarr;</a>
    </div>
    <div class="grid gap-6 md:grid-cols-3">
      {artifacts.map((artifact) => <ArtifactCard artifact={artifact} />)}
    </div>
  </section>

  <Timeline />
</BaseLayout>
