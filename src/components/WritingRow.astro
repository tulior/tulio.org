---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../lib/dates';

type Props = { post: CollectionEntry<'writing'>; headingLevel?: 'h2' | 'h3' };
const { post, headingLevel = 'h3' } = Astro.props;
const Heading = headingLevel;
---

<article class="border-b border-border last:border-b-0">
  <a href={`/writing/${post.id}/`} class="grid gap-2 p-4 transition hover:bg-surface-raised/55 md:grid-cols-[9rem_1fr] md:p-5">
    <time class="font-mono text-xs tabular-nums text-warm" datetime={post.data.date.toISOString()}>
      {formatDate(post.data.date)}
    </time>
    <div>
      <Heading class="font-mono text-base text-text-primary">{post.data.title}</Heading>
      <p class="mt-2 text-sm leading-6 text-text-secondary">{post.data.description}</p>
    </div>
  </a>
</article>
