---
import type { TimelineItem as TimelineItemType } from '../data/timeline';

type Props = { item: TimelineItemType };
const { item } = Astro.props;
const current = item.tone === 'current';

function presentStack(stack: readonly string[], max = 6): string {
  const simplified = stack.map((tag) => tag.replace(/\s+v?\d+(?:\.\d+)*$/i, ''));
  const shown = simplified.slice(0, max).join(' · ');
  return simplified.length > max ? `${shown} · …` : shown;
}
---

<li class="grid gap-2 border-t border-border py-6 md:grid-cols-[11rem_minmax(0,76ch)] md:gap-6">
  <div class:list={['font-mono text-xs tabular-nums leading-6', current ? 'text-primary' : 'text-text-muted']}>
    {item.period}
  </div>

  <article>
    <h3 class="text-base font-semibold text-text-primary">{item.title}</h3>
    {item.place && <p class="mt-1 font-mono text-xs leading-6 text-text-muted">{item.place}</p>}
    <p class="mt-3 text-pretty text-sm leading-7 text-text-secondary">{item.summary}</p>
    {item.stack && item.stack.length > 0 && (
      <p class="mt-3 font-mono text-xs leading-6 text-text-muted">
        {presentStack(item.stack)}
      </p>
    )}
  </article>
</li>
