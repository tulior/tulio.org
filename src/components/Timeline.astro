---
import { timeline } from '../data/timeline';
import TimelineItem from './TimelineItem.astro';
---

<section id="work" class="mx-auto max-w-6xl px-5 py-8 sm:px-8 lg:px-12">
  <h2 class="mb-6 font-display text-3xl font-semibold tracking-[-0.04em] text-text-primary">Work trace</h2>
  <ol class="relative space-y-0 before:absolute before:bottom-8 before:left-[0.72rem] before:top-8 before:w-px before:bg-border">
    {timeline.map((item) => <TimelineItem item={item} />)}
  </ol>
</section>
