---
import { navItems } from '../data/nav';

const pathname = Astro.url.pathname;

function normalize(path: string): string {
  return path.length > 1 ? path.replace(/\/$/, '') : path;
}

function isCurrent(href: string): boolean {
  if (!href.startsWith('/')) {
    return false;
  }

  const current = normalize(pathname);
  const target = normalize(href);
  return current === target || current.startsWith(`${target}/`);
}
---

<header class="px-5 py-5 sm:px-8 lg:px-12">
  <div class="mx-auto flex max-w-6xl items-baseline justify-between gap-5">
    <a href="/" class="shrink-0 font-mono text-sm font-semibold tracking-[0.08em] text-text-primary" aria-label="tulio.org home">
      tulio<span class="text-primary">.</span>org
    </a>

    <nav aria-label="Primary navigation" class="flex min-w-0 items-center gap-3 font-mono text-[0.8rem] tracking-[0.08em]">
      {navItems.map((item, index) => {
        const active = isCurrent(item.href);

        return (
          <span class="contents">
            {index > 0 && <span class="text-border-strong" aria-hidden="true">/</span>}
            <a
              href={item.href}
              aria-current={active ? 'page' : undefined}
              class:list={[
                'transition',
                active ? 'text-text-primary' : 'text-text-muted hover:text-text-primary',
              ]}
            >
              {item.label}
            </a>
          </span>
        );
      })}
    </nav>
  </div>
</header>
