---
import { site } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="border-t border-border px-5 py-8 sm:px-8 lg:px-12">
  <div class="flex flex-col gap-3 font-mono text-xs text-text-muted sm:flex-row sm:items-center sm:justify-between">
    <p>&copy; {year} {site.name}</p>
    <div class="flex gap-4">
      <a href={site.github} class="hover:text-primary" rel="noreferrer">GitHub</a>
      <a href={site.linkedin} class="hover:text-primary" rel="noreferrer">LinkedIn</a>
      <a href="/rss.xml" class="hover:text-primary">RSS</a>
      <a href={`mailto:${site.email}`} class="hover:text-primary">Email</a>
    </div>
  </div>
</footer>
