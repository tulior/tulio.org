---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Prose from '../components/Prose.astro';

type Props = { artifact: CollectionEntry<'artifacts'> };
const { artifact } = Astro.props;
const primaryExternal = artifact.data.primaryAction.href.startsWith('http');
const secondaryExternal = artifact.data.secondaryAction?.href.startsWith('http') ?? false;
---

<BaseLayout title={`${artifact.data.title} | Artifacts | tulio.org`} description={artifact.data.description}>
  <article class="px-5 py-12 sm:px-8 lg:px-12">
    <a href="/artifacts/" class="font-mono text-sm text-primary hover:text-primary-soft">&larr; Artifacts</a>

    <header class="mt-8 max-w-3xl">
      <p class="field-label">{artifact.data.type.replaceAll('-', ' ')} · {artifact.data.status}</p>
      <h1 class="mt-3 text-balance font-mono text-4xl font-bold text-text-primary sm:text-5xl">
        {artifact.data.title}
      </h1>
      <p class="mt-5 text-pretty text-lg leading-8 text-text-secondary">{artifact.data.description}</p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href={artifact.data.primaryAction.href}
          class="rounded-md border border-primary px-4 py-2 font-mono text-sm text-primary transition hover:bg-primary hover:text-background"
          {...(primaryExternal ? { rel: 'noreferrer' } : {})}
        >
          {artifact.data.primaryAction.label}
        </a>
        {artifact.data.secondaryAction && (
          <a
            href={artifact.data.secondaryAction.href}
            class="rounded-md border border-border px-4 py-2 font-mono text-sm text-text-secondary transition hover:border-primary hover:text-primary"
            {...(secondaryExternal ? { rel: 'noreferrer' } : {})}
          >
            {artifact.data.secondaryAction.label}
          </a>
        )}
      </div>
    </header>

    {artifact.data.interactive && (
      <section class="panel @container-size mt-8 p-5">
        <p class="field-label">Live tool</p>
        <div id={`tool-${artifact.id}`} class="mt-4 grid gap-4 @md:grid-cols-[1fr_13rem]">
          <label class="grid gap-2 font-mono text-xs text-text-muted">
            Sample data
            <textarea
              class="min-h-36 resize-y rounded-lg border border-border bg-code-bg p-3 font-mono text-sm leading-6 text-text-secondary tab-2"
              readonly
            >12.4
13.1
13.8
14.2
15.0
15.7</textarea>
          </label>
          <div class="rounded-lg border border-border bg-surface-inset p-4">
            <p class="font-mono text-xs uppercase tracking-[0.14em] text-warm">Candidate fits</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {['Normal', 'Lognormal', 'Exponential', 'Gamma'].map((fit) => (
                <span class="rounded border border-border px-2 py-1 font-mono text-[0.68rem] uppercase tracking-[0.08em] text-text-muted">
                  {fit}
                </span>
              ))}
            </div>
            <p class="mt-4 text-sm leading-6 text-text-secondary">
              Static shell ready. Route-local JavaScript or a public API can attach here without changing the page model.
            </p>
          </div>
        </div>
        {artifact.data.toolModule && <script is:inline type="module" src={`/tools/${artifact.data.toolModule}.js`}></script>}
      </section>
    )}

    <Prose>
      <slot />
    </Prose>
  </article>
</BaseLayout>
