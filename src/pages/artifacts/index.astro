---
import { getCollection } from 'astro:content';
import ArtifactCard from '../../components/ArtifactCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const artifacts = (await getCollection('artifacts', ({ data }) => !data.draft)).sort((a, b) =>
  Number(b.data.featured) - Number(a.data.featured) || a.data.title.localeCompare(b.data.title),
);
---

<BaseLayout title="Artifacts | tulio.org" description="Links to small tools, repos, and this website.">
  <section class="px-5 py-12 sm:px-8 lg:px-12">
    <p class="field-label">Links</p>
    <h1 class="mt-3 text-balance font-mono text-4xl font-bold text-text-primary sm:text-5xl">Artifacts</h1>
    <p class="mt-5 max-w-2xl text-pretty leading-8 text-text-secondary">
      A few things I made and put somewhere public. Some are useful. Some are here because this site needed somewhere to
      point.
    </p>

    <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {artifacts.map((artifact) => <ArtifactCard artifact={artifact} />)}
    </div>
  </section>
</BaseLayout>
