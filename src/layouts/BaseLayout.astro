---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import Shell from '../components/Shell.astro';

const {
  title = 'Túlio Ribeiro dos Anjos | Backend Systems Engineer',
  description = 'Personal timeline, engineering artifacts, and writing from Túlio Ribeiro dos Anjos.',
  noindex = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SEO title={title} description={description} noindex={noindex} />
  </head>
  <body class="scrollbar-estuary">
    <Shell>
      <Header />
      <main id="main-content">
        <slot />
      </main>
      <Footer />
    </Shell>
  </body>
</html>
