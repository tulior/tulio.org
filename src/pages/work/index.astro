---
import Timeline from '../../components/Timeline.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Work trace" description="A short record of backend systems work, contracts, and production seams.">
  <section class="mx-auto max-w-6xl px-5 pb-5 pt-10 sm:px-8 sm:pt-12 lg:px-12">
    <h1 class="text-balance font-display text-5xl font-bold leading-[0.95] tracking-[-0.05em] text-text-primary sm:text-7xl">Work trace</h1>
    <p class="mt-6 max-w-2xl text-pretty leading-8 text-text-secondary">
      A short record of backend systems work, contracts, and production seams.
    </p>
  </section>

  <Timeline sectionLabel="work trace" />
</BaseLayout>
