---
import { site } from '../data/site';

const metadata = [
  '12+ years building production systems',
  '.NET / AWS / integrations / performance',
  site.workMode,
  site.location,
] as const;
---

<div class="mt-9 grid gap-px overflow-hidden rounded-[var(--radius-panel)] border border-border bg-border sm:grid-cols-2 lg:grid-cols-4">
  {metadata.map((item) => (
    <div class="bg-surface/90 p-4">
      <p class="font-mono text-sm leading-6 text-text-secondary">{item}</p>
    </div>
  ))}
</div>
