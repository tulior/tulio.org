---
import type { CollectionEntry } from 'astro:content';

type Props = { artifact: CollectionEntry<'artifacts'>; headingLevel?: 'h2' | 'h3' };
const { artifact, headingLevel = 'h3' } = Astro.props;
const Heading = headingLevel;

const typeLabel = artifact.data.type.replaceAll('-', ' ');
const primaryExternal = artifact.data.primaryAction.href.startsWith('http');
const secondaryExternal = artifact.data.secondaryAction?.href.startsWith('http') ?? false;
---

<article class="panel flex min-h-full flex-col p-4 transition hover:border-primary/70 md:p-5">
  <div class="flex items-center justify-between gap-3">
    <p class="font-mono text-[0.7rem] uppercase text-warm">{typeLabel}</p>
    <p class="rounded-[var(--radius-pill)] border border-border px-2 py-1 font-mono text-[0.7rem] uppercase text-text-muted">
      {artifact.data.status}
    </p>
  </div>

  <Heading class="mt-4 font-mono text-lg font-semibold text-text-primary">
    <a href={`/artifacts/${artifact.id}/`} class="hover:text-primary">{artifact.data.title}</a>
  </Heading>

  <p class="mt-3 text-pretty text-sm leading-6 text-text-secondary">{artifact.data.description}</p>

  {artifact.data.stack.length > 0 && (
    <ul class="mt-4 flex flex-wrap gap-2" aria-label="Stack">
      {artifact.data.stack.map((tag) => (
        <li class="rounded border border-border px-2 py-1 font-mono text-[0.7rem] uppercase text-text-muted">
          {tag}
        </li>
      ))}
    </ul>
  )}

  <div class="mt-auto flex flex-wrap gap-3 pt-5">
    <a
      href={artifact.data.primaryAction.href}
      class="rounded-md border border-primary px-3 py-2 font-mono text-xs text-primary transition hover:bg-primary hover:text-background"
      {...(primaryExternal ? { rel: 'noreferrer' } : {})}
    >
      {artifact.data.primaryAction.label}
    </a>
    {artifact.data.secondaryAction && (
      <a
        href={artifact.data.secondaryAction.href}
        class="rounded-md border border-border px-3 py-2 font-mono text-xs text-text-secondary transition hover:border-primary hover:text-primary"
        {...(secondaryExternal ? { rel: 'noreferrer' } : {})}
      >
        {artifact.data.secondaryAction.label}
      </a>
    )}
  </div>
</article>
