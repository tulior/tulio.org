---
import ArtifactCard from '../../components/ArtifactCard.astro';
import { getPublishedArtifacts } from '../../lib/content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const artifacts = await getPublishedArtifacts();
---

<BaseLayout title="Artifacts" description="Tools and repositories I have made public.">
  <section class="px-5 py-12 sm:px-8 lg:px-12">
    <h1 class="text-balance font-mono text-4xl font-bold text-text-primary sm:text-5xl">Artifacts</h1>
    <p class="mt-5 max-w-2xl text-pretty leading-8 text-text-secondary">
      Tools and repositories I have made public.
    </p>

    <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {artifacts.map((artifact) => <ArtifactCard artifact={artifact} headingLevel="h2" />)}
    </div>
  </section>
</BaseLayout>
