---
import { navItems } from '../data/nav';

const pathname = Astro.url.pathname;

function normalize(path: string): string {
  return path.length > 1 ? path.replace(/\/$/, '') : path;
}

function isCurrent(href: string): boolean {
  if (!href.startsWith('/')) {
    return false;
  }

  const current = normalize(pathname);
  const target = normalize(href);
  return current === target || current.startsWith(`${target}/`);
}
---

<header class="sticky top-0 z-50">
  <div class="flex w-full flex-wrap items-center justify-between gap-x-3 gap-y-2 rounded-t-[calc(var(--radius-shell)-1px)] rounded-b-[var(--radius-panel)] border-b border-border bg-background/88 px-3 py-3 backdrop-blur-md xs:px-4 sm:px-8 lg:px-12">
    <a href="/" class="shrink-0 font-mono text-base font-semibold tracking-[0.08em] text-primary sm:text-lg" aria-label="tulio.org home">
      tulio.org
    </a>

    <nav aria-label="Primary navigation" class="flex min-w-0 items-center gap-1 xs:gap-2 sm:gap-3">
      {navItems.map((item) => {
        const active = isCurrent(item.href);
        const cta = 'cta' in item && item.cta;
        const stateClass = active
          ? 'border-primary/70 bg-primary/10 text-primary'
          : cta
            ? 'border-primary text-primary hover:bg-primary hover:text-background'
            : 'border-transparent text-text-secondary hover:border-primary/45 hover:text-primary';

        return (
          <a
            href={item.href}
            aria-current={active ? 'page' : undefined}
            class:list={[
              'rounded-md border px-2 py-2 font-mono text-xs transition sm:px-3 sm:text-sm',
              stateClass,
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </nav>
  </div>
</header>
