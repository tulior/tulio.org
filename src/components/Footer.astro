---
import { site } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="px-5 py-8 sm:px-8 lg:px-12">
  <div class="mx-auto flex max-w-6xl flex-col gap-3 font-mono text-xs text-text-muted sm:flex-row sm:items-center sm:justify-between">
    <p>built in Campo Grande · no trackers · &copy; {year}</p>
    <div class="flex flex-wrap gap-x-4 gap-y-2">
      <a href={site.github} class="hover:text-text-primary" rel="noreferrer">github</a>
      <a href={site.linkedin} class="hover:text-text-primary" rel="noreferrer">linkedin</a>
      <a href="/rss.xml" class="hover:text-text-primary">rss</a>
      <a href={`mailto:${site.email}`} class="hover:text-text-primary">{site.email}</a>
    </div>
  </div>
</footer>
