---
import { Image } from 'astro:assets';
import portrait from '../assets/tulio-ribeiro-dos-anjos.jpg';
import ArtifactCard from '../components/ArtifactCard.astro';
import FieldLogMark from '../components/FieldLogMark.astro';
import PersonJsonLd from '../components/PersonJsonLd.astro';
import Timeline from '../components/Timeline.astro';
import WritingRow from '../components/WritingRow.astro';
import { getPublishedArtifacts, getPublishedWriting } from '../lib/content';
import BaseLayout from '../layouts/BaseLayout.astro';

const artifacts = (await getPublishedArtifacts()).filter((artifact) => artifact.data.featured).slice(0, 3);
const writing = (await getPublishedWriting()).slice(0, 3);
---

<BaseLayout>
  <PersonJsonLd slot="head" />

  <section class="relative px-5 pb-10 pt-12 sm:px-8 sm:pt-16 lg:px-12">
    <FieldLogMark />

    <div class="relative grid gap-8 lg:grid-cols-[minmax(0,1fr)_16rem] lg:items-start">
      <div class="max-w-3xl">
        <h1 class="text-balance font-mono text-4xl font-bold tracking-tight text-text-primary sm:text-5xl lg:text-6xl">
          Túlio Ribeiro dos Anjos
        </h1>
        <p class="mt-4 font-mono text-sm text-primary sm:text-base">
          Backend systems engineer, currently contracting at Velozient.
        </p>
        <p class="mt-3 font-mono text-sm text-primary-soft">Campo Grande, Brazil. Remote.</p>
        <p class="mt-5 max-w-2xl text-pretty text-base leading-8 text-text-secondary sm:text-lg">
          I work mostly in .NET, Java, AWS, and integrations: getting two systems to agree and stay agreed.
        </p>
      </div>

      <figure class="w-40 sm:w-48 lg:ml-auto lg:w-64">
        <div class="overflow-hidden rounded-[var(--radius-panel)] border border-border-strong bg-surface-inset">
          <Image
            src={portrait}
            alt="Túlio Ribeiro dos Anjos"
            width={512}
            height={512}
            loading="eager"
            class="aspect-square w-full object-cover"
            decoding="async"
            fetchpriority="high"
          />
        </div>
      </figure>
    </div>
  </section>

  <Timeline />

  <section id="artifacts" class="px-5 py-8 sm:px-8 lg:px-12">
    <div class="mb-4 flex items-end justify-between gap-4">
      <h2 class="font-mono text-2xl text-primary">Artifacts</h2>
      <a href="/artifacts/" class="font-mono text-xs text-primary hover:text-primary-soft">VIEW ALL &rarr;</a>
    </div>
    <div class="grid gap-4 md:grid-cols-3">
      {artifacts.map((artifact) => <ArtifactCard artifact={artifact} />)}
    </div>
  </section>

  <section id="writing" class="px-5 py-8 sm:px-8 lg:px-12">
    <div class="mb-4 flex items-end justify-between gap-4">
      <h2 class="font-mono text-2xl text-primary">Writing</h2>
      <a href="/writing/" class="font-mono text-xs text-primary hover:text-primary-soft">VIEW ALL &rarr;</a>
    </div>
    <div class="overflow-hidden rounded-[var(--radius-panel)] border border-border bg-surface/80">
      {writing.map((post) => <WritingRow post={post} />)}
    </div>
  </section>
</BaseLayout>
